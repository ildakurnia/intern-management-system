###################################
# Laravel Default Ignores
###################################
*.log
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
/auth.json
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor

###################################
# Laravel Runtime / Cache
###################################
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/app/public/*
!/storage/app/public/.gitkeep
/storage/framework/cache/*
!/storage/framework/cache/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep

###################################
# IDE & OS Files
###################################
.DS_Store
Thumbs.db
.idea/
.vscode/
.fleet/
.nova/
.zed/
/.phpunit.cache

###################################
# Homestead / Vagrant
###################################
Homestead.json
Homestead.yaml
